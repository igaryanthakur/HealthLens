{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/health",
      "destination": "/server.js"
    },
    {
      "source": "/((?!api/.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 60,
      "includeFiles": "{public/**,node_modules/@napi-rs/**}"
    }
  }
}
