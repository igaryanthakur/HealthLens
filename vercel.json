{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/health",
      "destination": "/api"
    },
    {
      "source": "/((?!api/.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "node_modules/{pdf-parse/dist/pdf-parse/cjs/pdf.worker.mjs,tesseract.js/src/worker-script/**,tesseract.js-core/tesseract-core-simd-lstm*,@napi-rs/canvas-linux-x64-gnu/**,@img/sharp-linux-x64/**}"
    }
  }
}
