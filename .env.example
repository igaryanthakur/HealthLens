PORT=5000
UPLOAD_MAX_SIZE_MB=10
PDF_MIN_TEXT_LENGTH=100
OCR_LANGUAGE=eng
PHI_REDACT=true
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: pin the prescription Vision model. Defaults to gemini-flash-latest;
# set to a stable pin (e.g. gemini-2.5-flash) if the alias is overloaded (503).
GEMINI_VISION_MODEL=gemini-flash-latest
JWT_SECRET=your_super_secret_string_here
