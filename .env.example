PORT=5000
# MongoDB connection string. Use a MongoDB Atlas SRV URI in production/shared envs.
# Falls back to mongodb://localhost:27017/healthlens if unset.
MONGODB_URI=mongodb://localhost:27017/healthlens
UPLOAD_MAX_SIZE_MB=10
PDF_MIN_TEXT_LENGTH=100
OCR_LANGUAGE=eng
PHI_REDACT=true
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: pin the prescription Vision model. Defaults to gemini-flash-latest;
# set to a stable pin (e.g. gemini-2.5-flash) if the alias is overloaded (503).
GEMINI_VISION_MODEL=gemini-flash-latest
# Longitudinal insights AI wording. The deterministic brief is always returned;
# set to "true" to additionally let Gemini reword it (8s timeout, no retry,
# deterministic fallback). Missing/any-other-value = deterministic only.
LONGITUDINAL_AI_ENABLED=true
JWT_SECRET=your_super_secret_string_here

# Cloudinary — optional; when set, uploaded reports are stored for Vault download
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Demo patient (run: npm run seed:demo)
# demo@healthlens.ai / DemoHealth2026!
# Optional: RESET_DEMO_PASSWORD=true to reset password on re-seed
